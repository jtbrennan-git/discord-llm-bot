# Discord Bot Token (required)
DISCORD_TOKEN=

# Command prefix (default: !)
COMMAND_PREFIX=!

# Direct messages are ignored by the bot runtime.
ALLOW_DMS=false

# LLM Configuration
# Chat model — regular text responses
LLM_MODEL=openrouter/owl-alpha

# Vision model — image analysis (when someone sends a photo)
VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Image generation — empty means free Pollinations.ai backend.
# Set a name like recraft/recraft-v4-pro for OpenRouter fallback (requires credits).
IMAGE_MODEL=

# LLM base URL (default: https://openrouter.ai/api/v1)
LLM_BASE_URL=

# API Key for LLM service (required)
LLM_API_KEY=

# Temperature (0.0-2.0, default: 0.8)
TEMPERATURE=0.8

# Max tokens per response (default: 512)
MAX_TOKENS=512

# Timeout for each LLM call in seconds (default: 45)
LLM_TIMEOUT_SECONDS=45

# System prompt for bot personality (optional)
SYSTEM_PROMPT=

# Dev user IDs for !admin access (comma-separated)
DEV_USER_IDS=

# Optional cross-server control plane
# Commands must be sent in CONTROL_GUILD_ID / CONTROL_CHANNEL_ID by CONTROL_ADMIN_IDS.
CONTROL_GUILD_ID=
CONTROL_CHANNEL_ID=
CONTROL_ADMIN_IDS=
DM_FORWARD_ADMIN_IDS=
TARGET_GUILD_ID=

# Path for !improve suggestion logs
IMPROVEMENTS_LOG=/tmp/bot_improvements.log

# Path for user profile SQLite database
PROFILES_DB=/tmp/bot_profiles.db

# Temporary trigger seed CSV. Imported into PROFILES_DB on startup if present.
TRIGGER_DEFAULTS_CSV=fellasbot_triggers_active.csv
TRIGGER_DEFAULTS_IMPORT_ENABLED=true

# Memory database path
MEMORY_DB_PATH=/tmp/bot_memory.db

# Style and topic learning
STYLE_GUIDE_DB_PATH=/tmp/discord_llm_bot_style.db
TOPIC_LOG_DB_PATH=/tmp/discord_llm_bot_topics.db
STYLE_LEARNING_ENABLED=true
STYLE_LEARNING_INTERVAL=50
STYLE_LEARNING_CONTEXT_LIMIT=80
TOPIC_LEARNING_ENABLED=true
PROFILE_CONTEXT_ENABLED=false
TOPIC_LEARNING_INTERVAL=40
TOPIC_LEARNING_CONTEXT_LIMIT=60
TOPIC_STARTER_ENABLED=true
TOPIC_STARTER_MIN_MESSAGES_SINCE_ACTION=25
TOPIC_STARTER_MIN_IDLE_SECONDS=900
TOPIC_STARTER_COOLDOWN_SECONDS=7200
TOPIC_STARTER_CHANCE=0
STYLE_TRANSLATION_PASS_ENABLED=false
ALLOW_DM_LEARNING=false
LEARNING_QUEUE_MAXSIZE=25
DRY_RUN_ACTIONS=false
ACTION_AUDIT_DB_PATH=/tmp/discord_llm_bot_actions.db
SPONTANEOUS_CHANCE_CAP=0.033
SPONTANEOUS_REACT_BOOST_PER_REACTION=0.02
SPONTANEOUS_REACT_BOOST_CAP=0.20
