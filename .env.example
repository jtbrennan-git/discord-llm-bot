# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Guild ID (optional, for guild-specific settings)
DISCORD_GUILD=your_guild_id_here

# Command prefix (default: !)
COMMAND_PREFIX=!

# Allow direct messages (default: true)
ALLOW_DMS=true

# LLM Configuration
# Model to use (default: gpt-3.5-turbo)
LLM_MODEL=gpt-3.5-turbo

# API Key for LLM service (required for cloud models)
LLM_API_KEY=your_api_key_here

# Temperature (0.0-2.0, default: 0.7)
TEMPERATURE=0.7

# Max tokens (default: 2048)
MAX_TOKENS=2048

# Response formatting
RESPONSE_PREFIX=
RESPONSE_SUFFIX=

# Only respond when mentioned (default: false)
MENTION_RESPONSE_ONLY=false

# Number of recent messages to remember (default: 10)
CACHE_SIZE=10

# System prompt for bot personality (optional)
# Example: "You are a friendly bot that hangs out with friends."
SYSTEM_PROMPT=