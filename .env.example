# Discord Bot Token (required)
DISCORD_TOKEN=

# Command prefix (default: !)
COMMAND_PREFIX=!

# Allow direct messages (default: true)
ALLOW_DMS=true

# LLM Configuration
# Chat model — regular text responses
LLM_MODEL=minimax/minimax-m2.5:free

# Vision model — image analysis (when someone sends a photo)
VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Image generation model — create images on request
IMAGE_MODEL=recraft/recraft-v4-pro

# LLM base URL (default: https://openrouter.ai/api/v1)
LLM_BASE_URL=

# API Key for LLM service (required)
LLM_API_KEY=

# Temperature (0.0-2.0, default: 0.8)
TEMPERATURE=0.8

# Max tokens per response (default: 512)
MAX_TOKENS=512

# System prompt for bot personality (optional)
SYSTEM_PROMPT=

# Dev user IDs for !admin access (comma-separated)
DEV_USER_IDS=

# Path for !improve suggestion logs
IMPROVEMENTS_LOG=/tmp/bot_improvements.log

# Path for user profile SQLite database
PROFILES_DB=/tmp/bot_profiles.db

# Memory database path
MEMORY_DB_PATH=/tmp/bot_memory.db
